    <button class="claude-btn claude-btn-secondary" onclick="claudeCloseEditor('command')">Close</button>
  </div>
</div>

<script>
var claudeApiUrl = '/plugins/claude-code/include/claude-code-api.php';
var claudeCurrentPath = {skill: '', command: ''};

function claudeSwitchTab(tab, btn) {
  document.querySelectorAll('.claude-tab-content').forEach(function(el) { el.classList.remove('active'); });
  document.querySelectorAll('.claude-tabs button').forEach(function(el) { el.classList.remove('active'); });
  document.getElementById('tab-' + tab).classList.add('active');
  btn.classList.add('active');
  if (tab === 'status') claudeRefreshStatus();
}

function claudeRefreshStatus() {
  fetch(claudeApiUrl + '?action=status')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var installEl = document.getElementById('claude-install-status');
      var versionEl = document.getElementById('claude-version');
      var authEl = document.getElementById('claude-auth-status');
      if (data.version) {
        installEl.innerHTML = '<span class="claude-status-badge ok">Installed</span>';
        versionEl.textContent = data.version;
      } else {
        installEl.innerHTML = '<span class="claude-status-badge error">Not Installed</span>';
        versionEl.textContent = 'N/A';
      }
      if (data.authenticated) {
        authEl.innerHTML = '<span class="claude-status-badge ok">Logged In</span>';
      } else {
        authEl.innerHTML = '<span class="claude-status-badge warn">Not Logged In — run <code>claude login</code> via SSH</span>';
      }
    })
    .catch(function() {});
}

function claudeShowMsg(msg, type) {
  var el = document.getElementById('claude-msg');
  el.style.display = 'block';
  el.className = 'claude-status-badge ' + type;
  el.style.padding = '10px';
  el.style.marginBottom = '10px';
  el.textContent = msg;
  setTimeout(function() { el.style.display = 'none'; }, 5000);
}

function saveConfigFile(which) {
  var content, action;
  if (which === 'claude-md') {
    content = document.getElementById('claude-md-editor').value;
    action = 'save-claude-md';
  } else {
    content = document.getElementById('settings-json-editor').value;
    action = 'save-settings-json';
  }
  fetch(claudeApiUrl + '?action=' + action, {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'content=' + encodeURIComponent(content)
  })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) claudeShowMsg('Saved successfully.', 'ok');
      else claudeShowMsg('Save failed: ' + (data.error || 'Unknown error'), 'error');
    })
    .catch(function(err) { claudeShowMsg('Save failed: ' + err, 'error'); });
}

function reloadConfigFile(which) {
  var action = (which === 'claude-md') ? 'read-claude-md' : 'read-settings-json';
  fetch(claudeApiUrl + '?action=' + action)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        if (which === 'claude-md') document.getElementById('claude-md-editor').value = data.content;
        else document.getElementById('settings-json-editor').value = data.content;
        claudeShowMsg('Reverted.', 'ok');
      }
    });
}

function claudeCreateFile(type) {
  var name = prompt('Enter ' + type + ' filename (lowercase, hyphens allowed):');
  if (!name) return;
  fetch(claudeApiUrl + '?action=create-file', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'type=' + encodeURIComponent(type) + '&name=' + encodeURIComponent(name)
  })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        claudeRefreshList(type);
        claudeCurrentPath[type] = data.path;
        document.getElementById(type + '-edit-name').textContent = data.path.split('/').pop();
        document.getElementById(type + '-editor').value = data.content;
        document.getElementById(type + '-editor-container').style.display = 'block';
      } else {
        claudeShowMsg('Create failed: ' + (data.error || 'Unknown error'), 'error');
      }
    })
    .catch(function(err) { claudeShowMsg('Create failed: ' + err, 'error'); });
}

function claudeLoadFile(type, path) {
  fetch(claudeApiUrl + '?action=read-file&type=' + encodeURIComponent(type) + '&path=' + encodeURIComponent(path))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        claudeCurrentPath[type] = path;
        document.getElementById(type + '-edit-name').textContent = path.split('/').pop();
        document.getElementById(type + '-editor').value = data.content;
        document.getElementById(type + '-editor-container').style.display = 'block';
      }
    });
}

function claudeSaveFile(type) {
  var path = claudeCurrentPath[type];
  var content = document.getElementById(type + '-editor').value;
  fetch(claudeApiUrl + '?action=save-file', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'type=' + encodeURIComponent(type) + '&path=' + encodeURIComponent(path) + '&content=' + encodeURIComponent(content)
  })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        claudeShowMsg('Saved.', 'ok');
        claudeRefreshList(type);
      } else {
        claudeShowMsg('Save failed: ' + (data.error || 'Unknown error'), 'error');
      }
    })
    .catch(function(err) { claudeShowMsg('Save failed: ' + err, 'error'); });
}

function claudeDeleteFile(type) {
  if (!confirm('Delete this file? This cannot be undone.')) return;
  var path = claudeCurrentPath[type];
  fetch(claudeApiUrl + '?action=delete-file', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'type=' + encodeURIComponent(type) + '&path=' + encodeURIComponent(path)
  })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        claudeShowMsg('Deleted.', 'ok');
        claudeRefreshList(type);
        claudeCloseEditor(type);
      } else {
        claudeShowMsg('Delete failed: ' + (data.error || 'Unknown error'), 'error');
      }
    })
    .catch(function(err) { claudeShowMsg('Delete failed: ' + err, 'error'); });
}

function claudeCloseEditor(type) {
  document.getElementById(type + '-editor-container').style.display = 'none';
  claudeCurrentPath[type] = '';
}

function claudeRefreshList(type) {
  fetch(claudeApiUrl + '?action=list-files&type=' + encodeURIComponent(type))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.success) return;
      var container = document.getElementById(type + '-list');
      if (data.files.length === 0) {
        container.innerHTML = '<p class="file-list-empty">No ' + type + 's yet.</p>';
        return;
      }
      var html = '';
      for (var i = 0; i < data.files.length; i++) {
        var f = data.files[i];
        var safePath = f.path.replace(/'/g, "\\'");
        html += '<div class="file-item" onclick="claudeLoadFile(\'' + type + '\',\'' + safePath + '\')">';
        html += '<div class="file-item-name">' + claudeEscHtml(f.filename) + '</div>';
        if (f.description) html += '<div class="file-item-desc">' + claudeEscHtml(f.description) + '</div>';
        html += '</div>';
      }
      container.innerHTML = html;
    });
}

function claudeEscHtml(s) {
  var d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

function launchClaude() {
  var w = window.open('', 'claude-code', 'width=1200,height=800');
  if (!w) { alert('Pop-up blocked. Please allow pop-ups for this site.'); return; }
  w.document.write('<html><head><title>Claude Code</title></head><body style="margin:0;background:#1a1a2e;color:#ccc;font-family:monospace;padding:20px;">Starting Claude Code...</body></html>');
  fetch('/plugins/claude-code/include/open-claude.php').then(function() {
    setTimeout(function() { w.location = '/webterminal/claude-code/'; w.focus(); }, 500);
  });
}

setInterval(function() {
  if (document.getElementById('tab-status').classList.contains('active')) {
    claudeRefreshStatus();
  }
}, 10000);
</script>
